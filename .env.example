# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ganesh-fruit-suppliers

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Ganesh Fruit Suppliers <your_email@gmail.com>

# Business Details (for invoices)
BUSINESS_NAME=Ganesh Fruit Suppliers
BUSINESS_ADDRESS=123 Market Road, Mumbai, Maharashtra 400001
BUSINESS_PHONE=+91 98765 43210
BUSINESS_EMAIL=ganeshfruits@example.com
BUSINESS_GST=27AABCU9603R1ZM

# Cloudinary (for file storage in production)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
